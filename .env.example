# Naukri login is via Google OAuth — no email/password needed here.
# On first run the bot opens a visible browser and waits for you to
# sign in with Google. The session is then saved to data/naukri_session.json
# and reused silently on every subsequent run.

# Match threshold (0–100). Only apply if score >= this value.
MATCH_THRESHOLD=20

# Search parameters
SEARCH_KEYWORDS=Senior Software Engineer,Backend Engineer,GenAI Engineer,AI Platform Engineer
SEARCH_LOCATION=Bengaluru
SEARCH_EXPERIENCE_MIN=4
SEARCH_EXPERIENCE_MAX=8
SEARCH_MAX_PAGES=1
# Schedule (minutes between each run)
SCHEDULE_INTERVAL_MINUTES=20

# Max jobs to apply per run (safety cap)
MAX_APPLY_PER_RUN=10

# Only apply to "Easy Apply" jobs
EASY_APPLY_ONLY=false

# Skip companies already applied to (comma-separated, add as you go)
SKIP_COMPANIES=

# Headless browser (true = no visible window)
# Set false for first run to handle OTP/CAPTCHA
HEADLESS=false

# Paths
DB_PATH=data/naukribot.db
RESUME_PATH=resume/resume.json
LOG_PATH=logs/naukribot.log
SCREENSHOTS_PATH=screenshots
